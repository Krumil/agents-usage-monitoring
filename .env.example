# Copy to .env and fill in. .env is gitignored.

# --- Server ---
PORT=4318
HOST=0.0.0.0
DATABASE_PATH=.data/claude-usage.sqlite

# Plan limits source: "fetch" reads the local OAuth token; "push" serves a
# snapshot sent by the limits pusher (used for remote deployment).
LIMITS_SOURCE=fetch

# Required when LIMITS_SOURCE=push. Protects POST /api/limits/ingest; the server
# refuses to start in push mode without it.
LIMITS_INGEST_SECRET=

# --- Telegram session-refresh alerts (fetch mode) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web Push phone notifications (push mode) ---
# Generate once: npx web-push generate-vapid-keys
# Push features activate only when all three are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Hour (0-23, server local time) to push a daily cost/token/session summary.
# Leave empty to disable.
DAILY_SUMMARY_HOUR=

# --- Limits pusher (runs on your local machine, not the remote server) ---
DASHBOARD_INGEST_URL=
DASHBOARD_INGEST_AUTH=
LIMITS_PUSH_INTERVAL_MS=60000
