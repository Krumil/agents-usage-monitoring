{
  "name": "agents-usage-monitoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:e2e": "rm -f .data/e2e.sqlite && PORT=4328 DATABASE_PATH=.data/e2e.sqlite API_TARGET=http://127.0.0.1:4328 concurrently -k -n server,client \"tsx src/server/index.ts\" \"vite --host 0.0.0.0 --port 6173\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
